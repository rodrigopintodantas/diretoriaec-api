NODE_ENV=stage
PORT=3000

DB_USER=base
DB_PASSWORD=initial123
DB_DATABASE=base
DB_HOST=127.0.0.1
DB_PORT=5447
DB_DIALECT=postgres

# JWT (obrigatório em produção — use valor longo e aleatório)
JWT_SECRET=
# Opcional, ex.: 7d ou 24h
# JWT_EXPIRES_IN=7d

# Web Push (notificações no navegador/celular). Gere com: npm run push:keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Opcional — use um e-mail real em produção
VAPID_SUBJECT=mailto:contato@localhost
