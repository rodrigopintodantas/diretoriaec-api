{
  "name": "base-api",
  "version": "0.1.0",
  "private": true,
  "main": "bin/www",
  "scripts": {
    "start:with-migrate": "npm run db:migrate && npm run dev",
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:create": "sequelize-cli db:create",
    "db:drop": "sequelize-cli db:drop",
    "push:keys": "node scripts/generate-vapid-keys.js"
  },
  "keywords": [
    "backend",
    "express",
    "sequelize",
    "postgres",
    "docker"
  ],
  "author": "",
  "license": "ISC",
  "description": "Projeto base de backend com autenticação e PostgreSQL.",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  }
}
